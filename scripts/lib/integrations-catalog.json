{
  "schema_version": 2,
  "categories": [
    "docs-research",
    "backend",
    "payments",
    "email",
    "workspace",
    "project-management",
    "communication",
    "design",
    "dev-tools",
    "monitoring"
  ],
  "components": {
    "mcp": {
      "aws-cloudwatch-logs": {
        "name": "aws-cloudwatch-logs",
        "display_name": "AWS CloudWatch Logs",
        "category": "backend",
        "env_var_keys": [
          "AWS_ACCESS_KEY_ID",
          "AWS_SECRET_ACCESS_KEY",
          "AWS_REGION"
        ],
        "install_args": [
          "aws-cloudwatch-logs",
          "--",
          "uvx",
          "awslabs.cloudwatch-logs-mcp-server@latest"
        ],
        "description": "Live log streams + filter patterns + insights queries",
        "requires_oauth": false,
        "default_scope": "project"
      },
      "aws-cost-explorer": {
        "name": "aws-cost-explorer",
        "display_name": "AWS Cost Explorer",
        "category": "backend",
        "env_var_keys": [
          "AWS_ACCESS_KEY_ID",
          "AWS_SECRET_ACCESS_KEY",
          "AWS_REGION"
        ],
        "install_args": [
          "aws-cost-explorer",
          "--",
          "uvx",
          "awslabs.cost-explorer-mcp-server@latest"
        ],
        "description": "Query AWS spend + forecasts via natural language",
        "requires_oauth": false,
        "default_scope": "project"
      },
      "calendly": {
        "name": "calendly",
        "display_name": "Calendly",
        "category": "workspace",
        "env_var_keys": [],
