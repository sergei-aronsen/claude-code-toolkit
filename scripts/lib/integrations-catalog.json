          "--",
          "npx",
          "-y",
          "@chaindead/telegram-mcp"
        ],
        "description": "User-account API — read dialogs, send messages, manage channels (community)",
        "requires_oauth": false,
        "unofficial": true,
        "default_scope": "project"
      },
      "youtrack": {
        "name": "youtrack",
        "display_name": "YouTrack",
        "category": "project-management",
        "env_var_keys": [
          "YOUTRACK_URL",
          "YOUTRACK_TOKEN"
        ],
        "install_args": [
          "youtrack",
          "--",
          "npx",
          "-y",
          "youtrack-mcp"
        ],
        "description": "JetBrains issue tracker — query, create, update issues + log work",
        "requires_oauth": false,
        "default_scope": "user"
      }
    },
    "cli": {
      "aws-cloudwatch-logs": {
        "detect_cmd": "aws",
        "install": {
          "darwin": "brew install awscli",
          "linux": "curl \"https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip\" -o /tmp/awscliv2.zip && unzip -q /tmp/awscliv2.zip -d /tmp && /tmp/aws/install --install-dir ~/.local/aws-cli --bin-dir ~/.local/bin && rm -rf /tmp/aws /tmp/awscliv2.zip"
        },
        "post_install_hint": "aws configure"
      },
      "aws-cost-explorer": {
        "detect_cmd": "aws",
        "install": {
          "darwin": "brew install awscli",
          "linux": "curl \"https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip\" -o /tmp/awscliv2.zip && unzip -q /tmp/awscliv2.zip -d /tmp && /tmp/aws/install --install-dir ~/.local/aws-cli --bin-dir ~/.local/bin && rm -rf /tmp/aws /tmp/awscliv2.zip"
        },
        "post_install_hint": "aws configure"
      },
      "cloudflare": {
        "detect_cmd": "wrangler",
        "install": {
          "darwin": "npm install -g wrangler",
          "linux": "npm install -g wrangler"
        },
        "post_install_hint": "wrangler login"
      },
      "firecrawl": {
        "detect_cmd": "firecrawl",
        "install": {
          "darwin": "npm install -g firecrawl-cli",
          "linux": "npm install -g firecrawl-cli"
        },
        "post_install_hint": "firecrawl --version  # set FIRECRAWL_API_KEY env"
      },
      "playwright": {
        "detect_cmd": "playwright",
        "install": {
          "darwin": "npm install -g @playwright/test && npx playwright install",
          "linux": "npm install -g @playwright/test && npx playwright install"
        },
        "post_install_hint": "playwright --version  # browsers installed to ~/.cache/ms-playwright/"
      },
      "sentry": {
        "detect_cmd": "sentry-cli",
        "install": {
          "darwin": "brew install getsentry/tools/sentry-cli",
          "linux": "curl -sL https://sentry.io/get-cli/ | INSTALL_DIR=$HOME/.local/bin bash"
        },
        "post_install_hint": "sentry-cli login  # or set SENTRY_AUTH_TOKEN env"
      },
      "stripe": {
        "detect_cmd": "stripe",
        "install": {
          "darwin": "brew install stripe/stripe-cli/stripe",
          "linux": "mkdir -p ~/.local/bin && curl -fsSL https://github.com/stripe/stripe-cli/releases/latest/download/stripe_linux_x86_64.tar.gz | tar -xz -C ~/.local/bin/ stripe"
        },
        "post_install_hint": "stripe login"
      },
      "supabase": {
        "detect_cmd": "supabase",
        "install": {
          "darwin": "brew install supabase/tap/supabase",
          "linux": "npm install -g supabase"
        },
        "post_install_hint": "supabase login"
      }
    }
  }
}
