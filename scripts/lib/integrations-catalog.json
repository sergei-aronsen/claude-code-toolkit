{
  "schema_version": 2,
  "categories": [
    "docs-research",
    "backend",
    "payments",
    "email",
    "workspace",
    "project-management",
    "communication",
    "design",
    "dev-tools",
    "monitoring"
  ],
  "components": {
    "mcp": {
      "aws-cloudwatch-logs": {
        "name": "aws-cloudwatch-logs",
        "display_name": "AWS CloudWatch Logs",
        "category": "backend",
        "env_var_keys": [
          "AWS_ACCESS_KEY_ID",
          "AWS_SECRET_ACCESS_KEY",
          "AWS_REGION"
        ],
        "install_args": [
          "aws-cloudwatch-logs",
          "--",
          "uvx",
          "awslabs.cloudwatch-logs-mcp-server@latest"
        ],
        "description": "Live log streams + filter patterns + insights queries",
        "requires_oauth": false
      },
      "aws-cost-explorer": {
        "name": "aws-cost-explorer",
        "display_name": "AWS Cost Explorer",
        "category": "backend",
        "env_var_keys": [
          "AWS_ACCESS_KEY_ID",
          "AWS_SECRET_ACCESS_KEY",
          "AWS_REGION"
        ],
        "install_args": [
          "aws-cost-explorer",
          "--",
          "uvx",
          "awslabs.cost-explorer-mcp-server@latest"
        ],
        "description": "Query AWS spend + forecasts via natural language",
        "requires_oauth": false
      },
      "cloudflare": {
        "name": "cloudflare",
        "display_name": "Cloudflare",
        "category": "backend",
        "env_var_keys": [
          "CLOUDFLARE_API_TOKEN"
        ],
        "install_args": [
          "cloudflare",
          "--",
          "npx",
          "-y",
          "@cloudflare/mcp-server-cloudflare"
        ],
        "description": "Workers, R2, KV, D1 — edge platform",
        "requires_oauth": false
      },
      "context7": {
        "name": "context7",
        "display_name": "Context7",
        "category": "docs-research",
        "env_var_keys": [
          "CONTEXT7_API_KEY"
        ],
        "install_args": [
          "context7",
          "--",
          "npx",
          "-y",
          "@upstash/context7-mcp"
        ],
        "description": "Up-to-date library docs (React, Next.js, Tailwind, etc.)",
        "requires_oauth": false
      },
      "firecrawl": {
        "name": "firecrawl",
        "display_name": "Firecrawl",
        "category": "docs-research",
        "env_var_keys": [
          "FIRECRAWL_API_KEY"
        ],
        "install_args": [
          "firecrawl",
          "--",
          "npx",
          "-y",
          "firecrawl-mcp"
        ],
        "description": "Website scraping + crawling",
        "requires_oauth": false
      },
      "magic": {
        "name": "magic",
        "display_name": "Magic",
        "category": "dev-tools",
        "env_var_keys": [
          "MAGIC_API_KEY"
        ],
        "install_args": [
          "magic",
          "--",
          "npx",
          "-y",
          "@21st-dev/magic"
        ],
        "description": "UI component generation (21st.dev)",
        "requires_oauth": false
      },
      "notion": {
        "name": "notion",
        "display_name": "Notion",
        "category": "workspace",
        "env_var_keys": [],
        "install_args": [
          "notion",
          "--",
          "npx",
          "-y",
          "@notionhq/notion-mcp-server"
        ],
        "description": "Workspace pages + databases (OAuth)",
        "requires_oauth": true
      },
      "openrouter": {
        "name": "openrouter",
        "display_name": "OpenRouter",
        "category": "dev-tools",
        "env_var_keys": [
          "OPENROUTER_API_KEY"
        ],
        "install_args": [
          "openrouter",
          "--",
          "npx",
          "-y",
          "openrouter-mcp"
        ],
        "description": "Multi-model LLM routing",
        "requires_oauth": false
      },
      "playwright": {
        "name": "playwright",
        "display_name": "Playwright",
        "category": "dev-tools",
        "env_var_keys": [],
        "install_args": [
          "playwright",
          "--",
          "npx",
          "-y",
          "@playwright/mcp"
        ],
        "description": "Browser automation + screenshot",
        "requires_oauth": false
      },
      "resend": {
        "name": "resend",
        "display_name": "Resend",
        "category": "email",
        "env_var_keys": [
          "RESEND_API_KEY"
        ],
        "install_args": [
          "resend",
          "--",
          "npx",
          "-y",
          "@resend/mcp-send-email"
        ],
        "description": "Transactional email send",
        "requires_oauth": false
      },
      "sentry": {
        "name": "sentry",
        "display_name": "Sentry",
        "category": "monitoring",
        "env_var_keys": [
          "SENTRY_AUTH_TOKEN"
        ],
        "install_args": [
          "sentry",
          "--",
          "npx",
          "-y",
          "@sentry/mcp-server"
        ],
        "description": "Error monitoring + issue triage",
        "requires_oauth": false
      },
      "sequential-thinking": {
        "name": "sequential-thinking",
        "display_name": "Sequential Thinking",
        "category": "dev-tools",
        "env_var_keys": [],
        "install_args": [
          "sequential-thinking",
          "--",
          "npx",
          "-y",
          "@modelcontextprotocol/server-sequential-thinking"
        ],
        "description": "Structured step-by-step reasoning (zero-config)",
        "requires_oauth": false
      },
      "supabase": {
        "name": "supabase",
        "display_name": "Supabase",
        "category": "backend",
        "env_var_keys": [
          "SUPABASE_ACCESS_TOKEN"
        ],
        "install_args": [
          "supabase",
          "--",
          "npx",
          "-y",
          "@supabase/mcp-server-supabase"
        ],
        "description": "Postgres + auth + storage + edge functions backend",
        "requires_oauth": false
      }
    },
    "cli": {
      "aws-cloudwatch-logs": {
        "detect_cmd": "aws",
        "install": {
          "darwin": "brew install awscli",
          "linux": "curl \"https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip\" -o /tmp/awscliv2.zip && unzip -q /tmp/awscliv2.zip -d /tmp && /tmp/aws/install --install-dir ~/.local/aws-cli --bin-dir ~/.local/bin && rm -rf /tmp/aws /tmp/awscliv2.zip"
        },
        "post_install_hint": "aws configure"
      },
      "aws-cost-explorer": {
        "detect_cmd": "aws",
        "install": {
          "darwin": "brew install awscli",
          "linux": "curl \"https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip\" -o /tmp/awscliv2.zip && unzip -q /tmp/awscliv2.zip -d /tmp && /tmp/aws/install --install-dir ~/.local/aws-cli --bin-dir ~/.local/bin && rm -rf /tmp/aws /tmp/awscliv2.zip"
        },
        "post_install_hint": "aws configure"
      },
      "cloudflare": {
        "detect_cmd": "wrangler",
        "install": {
          "darwin": "npm install -g wrangler",
          "linux": "npm install -g wrangler"
        },
        "post_install_hint": "wrangler login"
      },
      "supabase": {
        "detect_cmd": "supabase",
        "install": {
          "darwin": "brew install supabase/tap/supabase",
          "linux": "npm install -g supabase"
        },
        "post_install_hint": "supabase login"
      }
    }
  }
}
