.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Temp files
*.tmp
*.bak
*.log

# Claude Code local setup (not toolkit content)
.claude/

# Python bytecode (from validate-commands.py etc.)
__pycache__/
*.pyc

# Skills Desktop-safety audit artifact (runtime output — do not commit)
.audit-skills-desktop.txt

# External vendor code for read-only analysis (never bundle/distribute)
_external/

# Serena MCP runtime state (project.yml, memories cache, .serena/cache)
.serena/

# Personal MCP config (Comet bridge experiment) — not toolkit content
.mcp.json

# GSD scratchpad ephemera — per-task quick notes, codebase mapping cache,
# and audit dumps. Active state (PROJECT.md, ROADMAP.md, MILESTONES.md,
# STATE.md, RETROSPECTIVE.md, INBOX.md, config.json, research/) stays
# tracked. Historical artifacts live in the claude-memo vault at
# references/toolkit-history/ — see scripts/archive-planning-to-vault.sh.
.planning/quick/
.planning/codebase/
.planning/audits/
