{
  "version": "1.0",
  "description": "Skill activation rules — Claude suggests relevant skills based on triggers. v6: testing/debugging removed (covered by Superpowers TDD + systematic-debugging plugin skills).",
  "skills": {
    "docker": {
      "path": ".claude/skills/docker/SKILL.md",
      "description": "Docker and container best practices",
      "triggers": {
        "keywords": [
          "docker",
          "container",
          "dockerfile",
          "compose"
        ],
        "intentPatterns": [
          "containerize.*",
          "create.*docker",
          "add.*container"
        ],
        "filePatterns": [
          "Dockerfile*",
          "docker-compose*",
          ".dockerignore"
        ]
      }
    },
    "api-design": {
      "path": ".claude/skills/api-design/SKILL.md",
      "description": "REST API design: naming, status codes, OpenAPI",
      "triggers": {
        "keywords": [
          "api",
          "rest",
          "endpoint",
          "openapi",
          "swagger"
        ],
        "intentPatterns": [
          "design.*api",
          "create.*endpoint",
          "add.*route"
        ],
        "filePatterns": [
          "**/api/**",
          "**/routes/**",
          "openapi.*",
          "swagger.*"
        ]
      }
    },
    "database": {
      "path": ".claude/skills/database/SKILL.md",
      "description": "Database: migrations, indexes, N+1 prevention",
      "triggers": {
        "keywords": [
          "database",
          "migration",
          "index",
          "query",
          "sql",
          "orm"
        ],
        "intentPatterns": [
          "create.*migration",
          "optimize.*query",
          "add.*index"
        ],
        "filePatterns": [
          "**/migrations/**",
          "**/models/**",
          "schema.*"
        ]
      }
    },
    "observability": {
      "path": ".claude/skills/observability/SKILL.md",
      "description": "Logging, metrics, tracing, monitoring",
      "triggers": {
        "keywords": [
          "logging",
          "metrics",
          "tracing",
          "monitoring",
          "observability"
        ],
        "intentPatterns": [
          "add.*logging",
          "setup.*monitoring",
          "add.*metrics"
        ],
        "filePatterns": [
          "**/logging/**",
          "**/metrics/**",
          "prometheus.*"
        ]
      }
    },
    "llm-patterns": {
      "path": ".claude/skills/llm-patterns/SKILL.md",
      "description": "LLM integration: RAG, streaming, tool use",
      "triggers": {
        "keywords": [
          "rag",
          "embeddings",
          "vector",
          "llm",
          "prompt",
          "streaming"
        ],
        "intentPatterns": [
          "implement.*rag",
          "add.*embeddings",
          "create.*chat"
        ],
        "filePatterns": [
          "**/ai/**",
          "**/llm/**",
          "**/rag/**",
          "**/embeddings/**"
        ]
      }
    },
    "council-integration": {
      "path": ".claude/skills/council-integration/SKILL.md",
      "description": "Supreme Council integration with GSD plan/execute and audit workflows; verdict-handling rules (PROCEED/SIMPLIFY/RETHINK/SKIP)",
      "triggers": {
        "keywords": [
          "council",
          "skeptic",
          "pragmatist",
          "/council",
          "council audit-review",
          "rethink verdict",
          "council pass"
        ],
        "intentPatterns": [
          ".*--council\\b.*",
          "run.*council",
          "validate.*plan.*council",
          "council.*verdict"
        ],
        "filePatterns": [
          ".claude/scratchpad/council-report.md",
          ".claude/audits/**"
        ]
      }
    }
  }
}
