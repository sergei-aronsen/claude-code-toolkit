{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$FILE_PATH\" == *.go ]]; then gofmt -w \"$FILE_PATH\" 2>/dev/null || true; fi"
          },
          {
            "type": "command",
            "command": "echo '[$(date +%H:%M:%S)] Modified: $FILE_PATH' >> .claude/activity.log"
          }
        ]
      }
    ],
    "PreToolUse": [],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[$(date +%Y-%m-%d %H:%M:%S)] Session ended: $(pwd)' >> ~/.claude/sessions.log"
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "Grep(*)",
      "Glob(*)",

      "Bash(go *)",
      "Bash(golangci-lint *)",
      "Bash(air *)",
      "Bash(mockgen *)",
      "Bash(wire *)",


      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(dd if=*)",
      "Bash(go clean -cache -modcache -testcache)"
    ]
  }
}
