    "i18n": {
      "path": ".claude/skills/i18n/SKILL.md",
      "description": "Internationalization: translations, localization, multilanguage",
      "triggers": {
        "keywords": [
          "i18n",
          "l10n",
          "translation",
          "localization",
          "multilanguage",
          "locale",
          "internationalization"
        ],
        "intentPatterns": [
          "add.*language",
          "translate.*",
