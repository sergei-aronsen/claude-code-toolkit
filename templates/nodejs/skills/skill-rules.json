          "query",
          "prisma",
          "drizzle"
        ],
        "intentPatterns": [
          "create.*migration",
          "optimize.*query",
          "add.*index"
        ],
        "filePatterns": [
          "**/migrations/**",
          "**/models/**",
          "schema.prisma",
          "drizzle/**"
        ]
      }
    },
    "observability": {
      "path": ".claude/skills/observability/SKILL.md",
      "description": "Logging, metrics, tracing (Pino, OpenTelemetry)",
      "triggers": {
        "keywords": [
