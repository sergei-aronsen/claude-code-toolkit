          "localize.*",
          "support.*languages"
        ],
        "filePatterns": [
          "**/lang/**",
          "**/locales/**",
          "**/i18n/**",
          "**/translations/**"
        ]
      }
    },
    "debugging": {
      "path": ".claude/skills/debugging/SKILL.md",
      "description": "Systematic debugging and root cause analysis",
      "triggers": {
        "keywords": [
          "debug",
          "fix",
          "error",
          "bug",
          "crash",
          "stack trace",
          "exception"
        ],
        "intentPatterns": [
          "fix.*bug",
          "debug.*issue",
          "resolve.*error",
