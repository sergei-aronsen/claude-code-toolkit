        ],
        "intentPatterns": [
          "add.*logging",
          "setup.*monitoring",
          "add.*metrics"
        ],
        "filePatterns": [
          "**/logging/**",
          "**/metrics/**",
          "prometheus.*"
        ]
      }
    },
    "llm-patterns": {
      "path": ".claude/skills/llm-patterns/SKILL.md",
