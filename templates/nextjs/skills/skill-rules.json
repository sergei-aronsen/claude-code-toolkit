{
  "version": "1.0",
  "description": "Skill activation rules — Claude suggests relevant skills based on triggers",
  "skills": {
    "ai-models": {
      "path": ".claude/skills/ai-models/SKILL.md",
      "description": "Current versions of AI models (Claude, Gemini)",
      "triggers": {
        "keywords": [
          "anthropic",
          "claude api",
          "gemini",
          "openai",
          "llm",
          "ai model"
        ],
        "intentPatterns": [
          "add.*model",
          "integrate.*api",
          "connect.*claude"
        ],
        "filePatterns": [
          "**/ai/**",
          "**/llm/**",
          "**/chat/**"
        ]
      }
    },
    "nextjs": {
      "path": ".claude/skills/nextjs/SKILL.md",
      "description": "Next.js App Router, Server Components, Server Actions",
      "triggers": {
        "keywords": [
          "next",
          "app router",
          "server component",
          "server action",
          "rsc"
        ],
        "intentPatterns": [
          "create.*page",
          "add.*route",
          "make.*api"
        ],
        "filePatterns": [
          "app/**/*.tsx",
          "app/**/route.ts",
          "app/**/page.tsx"
        ]
      }
    },
    "shadcn": {
      "path": ".claude/skills/shadcn/SKILL.md",
      "description": "shadcn/ui components best practices",
      "triggers": {
        "keywords": [
          "shadcn",
          "radix",
          "ui component",
          "dialog",
          "dropdown"
        ],
        "intentPatterns": [
          "add.*component",
          "create.*form",
          "make.*modal"
        ],
        "filePatterns": [
          "components/ui/**",
          "**/components/**/*.tsx"
        ]
      }
    },
    "tailwind": {
      "path": ".claude/skills/tailwind/SKILL.md",
      "description": "Tailwind CSS: utility classes, responsive, dark mode",
      "triggers": {
        "keywords": [
          "tailwind",
          "css",
          "styling",
          "dark mode",
          "responsive",
          "className"
        ],
        "intentPatterns": [
          "style.*",
          "add.*styles",
          "make.*responsive",
          "add.*dark mode"
        ],
        "filePatterns": [
          "**/*.tsx",
          "**/*.css",
          "tailwind.config.*",
          "globals.css"
        ]
      }
    },
    "docker": {
      "path": ".claude/skills/docker/SKILL.md",
      "description": "Docker and container best practices",
      "triggers": {
        "keywords": [
          "docker",
          "container",
          "dockerfile",
          "compose"
        ],
        "intentPatterns": [
          "containerize.*",
          "create.*docker",
          "add.*container"
        ],
        "filePatterns": [
          "Dockerfile*",
          "docker-compose*",
          ".dockerignore"
        ]
      }
    },
    "testing": {
      "path": ".claude/skills/testing/SKILL.md",
      "description": "Testing patterns: TDD, mocking, coverage (Vitest/Playwright)",
      "triggers": {
        "keywords": [
          "test",
          "testing",
          "tdd",
          "mock",
          "coverage",
          "e2e",
          "playwright"
        ],
        "intentPatterns": [
          "write.*test",
          "add.*test",
          "test.*"
        ],
        "filePatterns": [
          "**/*.test.ts",
          "**/*.spec.ts",
          "**/tests/**",
          "**/__tests__/**"
        ]
      }
    },
    "api-design": {
      "path": ".claude/skills/api-design/SKILL.md",
      "description": "REST API design: naming, status codes, OpenAPI",
